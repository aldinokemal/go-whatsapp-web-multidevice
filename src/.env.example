# Application Settings
APP_PORT=3000
APP_HOST=0.0.0.0
APP_DEBUG=false
APP_OS=Chrome
APP_BASIC_AUTH=user1:pass1,user2:pass2
APP_BASE_PATH=
APP_TRUSTED_PROXIES=0.0.0.0/0
# Restrict cross-origin browser access to specific origins (comma-separated); empty allows any origin
APP_CORS_ALLOWED_ORIGINS=

# Web UI (gowa-ui) Settings
# The dashboard is downloaded from the latest GitHub release of APP_UI_REPO
# and served at "/". Air-gap: pre-seed storages/ui/index.html and set
# APP_UI_AUTO_UPDATE=false, or turn the UI off entirely.
APP_UI_ENABLED=true
APP_UI_AUTO_UPDATE=true
APP_UI_REPO=aldinokemal/gowa-ui
APP_UI_ASSET_NAME=gowa-ui.html
APP_UI_UPDATE_INTERVAL=3h
APP_UI_GITHUB_TOKEN=
# Optional supply-chain pin: refuse any dashboard whose sha256 differs
# (hex digest; each release ships a gowa-ui.html.sha256 asset)
APP_UI_ASSET_SHA256=

# Database Settings
DB_URI=file:storages/whatsapp.db?_foreign_keys=on
DB_KEYS_URI=
# Max concurrent SQLite connections for chat storage (default: 5, min: 1).
# Increase if API sends time out under heavy incoming message load.
CHAT_STORAGE_MAX_OPEN_CONNS=5

# WhatsApp Settings
WHATSAPP_AUTO_REPLY="Auto reply message"
WHATSAPP_AUTO_MARK_READ=false
WHATSAPP_AUTO_REJECT_CALL=false
WHATSAPP_AUTO_DOWNLOAD_MEDIA=true
WHATSAPP_WEBHOOK=https://webhook.site/07b69616-5943-4c7f-a8be-db4819df699e,https://webhook.site/09a38aff-d11a-4a38-a176-3f3efa0b5e8b
WHATSAPP_WEBHOOK_SECRET=super-secret-key
WHATSAPP_WEBHOOK_INSECURE_SKIP_VERIFY=false
WHATSAPP_WEBHOOK_EVENTS=message,message.reaction,message.revoked,message.edited,message.ack,message.deleted,group.participants
# Comma-separated WhatsApp JIDs (or "@g.us"/"@s.whatsapp.net"/"@lid" wildcards) to skip when forwarding to the webhook.
# Example: "@g.us" drops all group traffic; add exact JIDs to mute specific chats/senders.
WHATSAPP_WEBHOOK_IGNORE_JIDS=
WHATSAPP_WEBHOOK_INCLUDE_OUTGOING=false
WHATSAPP_ACCOUNT_VALIDATION=true
WHATSAPP_PRESENCE_ON_CONNECT=unavailable
WHATSAPP_PRESENCE_PULSE_ENABLED=true
WHATSAPP_PRESENCE_PULSE_INTERVAL=24h
WHATSAPP_PRESENCE_PULSE_DURATION=5m
WHATSAPP_CHAT_STORAGE=true
# Outbound proxy applied to whatsmeow's WebSocket dialer via SetProxyAddress.
# Standard HTTP_PROXY env does not apply to the underlying ws connection.
# Useful for self-hosted deploys behind DPI / network egress restrictions.
# Supports SOCKS5/HTTP/HTTPS schemes. Empty = direct connection.
# Example: WHATSAPP_PROXY=socks5://user:pass@proxy.example.com:1080
WHATSAPP_PROXY=

# Chatwoot Integration
CHATWOOT_ENABLED=false
CHATWOOT_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=xxxxxxxx
CHATWOOT_ACCOUNT_ID=111111
CHATWOOT_INBOX_ID=000000
CHATWOOT_DEVICE_ID=
CHATWOOT_IMPORT_MESSAGES=false
CHATWOOT_DAYS_LIMIT_IMPORT_MESSAGES=3
CHATWOOT_IMPORT_DB_URI=
CHATWOOT_IMPORT_PLACEHOLDER_MEDIA_MESSAGE=true
CHATWOOT_IMPORT_MEDIA_WITH_REST=false
# Auto-provisioning: create/reuse the inbox on startup so CHATWOOT_INBOX_ID is optional
CHATWOOT_AUTO_CREATE=false
CHATWOOT_INBOX_NAME=WhatsApp
CHATWOOT_WEBHOOK_URL=
CHATWOOT_WEBHOOK_SECRET=
# Conversation handling
CHATWOOT_REOPEN_CONVERSATION=true
CHATWOOT_CONVERSATION_PENDING=false
CHATWOOT_IGNORE_JIDS=
# Outbound agent signature
CHATWOOT_SIGN_MSG=false
CHATWOOT_SIGN_DELIMITER="\n\n"
# Edit/delete propagation (WhatsApp -> Chatwoot)
CHATWOOT_FORWARD_EDITS=true
CHATWOOT_FORWARD_DELETES=true
# Evolution-compatible read/delete state sync
CHATWOOT_MESSAGE_READ=false
CHATWOOT_MESSAGE_DELETE=false
