# Application Settings
APP_PORT=3000
APP_HOST=0.0.0.0
APP_DEBUG=false
APP_OS=Chrome
APP_BASIC_AUTH=user1:pass1,user2:pass2
APP_BASE_PATH=
APP_TRUSTED_PROXIES=0.0.0.0/0
# Public base URL of this server (scheme + host, no trailing path), e.g. https://gowa.example.com
# Used to auto-register the Chatwoot webhook callback ({APP_PUBLIC_URL}{APP_BASE_PATH}/chatwoot/webhook)
# when creating/updating a Chatwoot device mapping. Leave empty to disable auto-registration.
APP_PUBLIC_URL=

# Database Settings
DB_URI=file:storages/whatsapp.db?_foreign_keys=on
DB_KEYS_URI=

# WhatsApp Settings
WHATSAPP_AUTO_REPLY="Auto reply message"
WHATSAPP_AUTO_MARK_READ=false
WHATSAPP_AUTO_REJECT_CALL=false
WHATSAPP_AUTO_DOWNLOAD_MEDIA=true
WHATSAPP_WEBHOOK=https://webhook.site/07b69616-5943-4c7f-a8be-db4819df699e,https://webhook.site/09a38aff-d11a-4a38-a176-3f3efa0b5e8b
WHATSAPP_WEBHOOK_SECRET=super-secret-key
WHATSAPP_WEBHOOK_INSECURE_SKIP_VERIFY=false
WHATSAPP_WEBHOOK_EVENTS=message,message.reaction,message.revoked,message.edited,message.ack,message.deleted,group.participants
WHATSAPP_WEBHOOK_INCLUDE_OUTGOING=false
WHATSAPP_ACCOUNT_VALIDATION=true
WHATSAPP_PRESENCE_ON_CONNECT=unavailable
WHATSAPP_PRESENCE_PULSE_ENABLED=true
WHATSAPP_PRESENCE_PULSE_INTERVAL=24h
WHATSAPP_PRESENCE_PULSE_DURATION=5m
WHATSAPP_CHAT_STORAGE=true

# Chatwoot Integration
# These CHATWOOT_* values are the single-device fallback/default. For multi-device /
# multi-inbox, manage per-device mappings via the REST API (/chatwoot/configs) or the
# web UI; on first run these env values are auto-migrated into one mapping.
# Delivery/read status sync and the agent "typing…" indicator work automatically;
# typing additionally requires an account-level Chatwoot webhook (Settings → Integrations →
# Webhooks) subscribed to conversation_typing_on/off pointing at {APP_PUBLIC_URL}/chatwoot/webhook.
CHATWOOT_ENABLED=false
CHATWOOT_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=xxxxxxxx
CHATWOOT_ACCOUNT_ID=111111
CHATWOOT_INBOX_ID=000000
CHATWOOT_DEVICE_ID=
CHATWOOT_IMPORT_MESSAGES=false
CHATWOOT_DAYS_LIMIT_IMPORT_MESSAGES=3
